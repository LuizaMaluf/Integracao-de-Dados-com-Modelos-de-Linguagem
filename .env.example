# ──────────────────────────────────────────────────────────────────
# Configuração do pipeline de integração semântica
# Copie este arquivo para .env e preencha os valores.
#
# Status atual do projeto
#   ✓  Contexto de domínio definido (CONTEXT.md)
#   ✓  Análise semântica local funcionando (sem API)
#   ✗  Raciocínio LLM desabilitado — falta ANTHROPIC_API_KEY
#
# Com a chave configurada, a skill identificar-chave ativa o modo
# Decision Layer (use_llm=True) e o pipeline passa a usar o modelo
# para justificar a Integration Key escolhida.
# ──────────────────────────────────────────────────────────────────

# [OBRIGATÓRIO para LLM] Chave da API Anthropic
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# [Opcional] Modelo LLM utilizado na Decision Layer
# Padrão: claude-sonnet-4-6
MODEL_NAME=claude-sonnet-4-6

# ──────────────────────────────────────────────────────────────────
# Limiares do pipeline (ajuste conforme o domínio)
# ──────────────────────────────────────────────────────────────────

# Match rate mínimo para um Candidate Key ser aceito
MIN_MATCH_RATE=0.5

# Confiança mínima para promover um candidato a Integration Key
MIN_CONFIDENCE=0.6

# Número máximo de Candidate Keys passados ao LLM por par de tabelas
MAX_CANDIDATE_KEYS=10

# ──────────────────────────────────────────────────────────────────
# Amostragem (afeta velocidade vs. precisão do overlap_stats)
# ──────────────────────────────────────────────────────────────────

# Linhas amostradas por tabela na Evidence Layer
SAMPLE_SIZE=1000
