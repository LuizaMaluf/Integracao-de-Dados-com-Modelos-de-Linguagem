# ── MinIO (Bronze Zone) ───────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_BRONZE=bronze

# ── DuckDB (Silver Zone) ─────────────────────────────────────────
# Path inside the container — mapped via docker-compose volume
DUCKDB_PATH=/opt/airflow/data/silver.duckdb

# ── Anthropic (Semantic PDF Parser) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
